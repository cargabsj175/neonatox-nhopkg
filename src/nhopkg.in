###############################################################################
#
#==============================================================================
# Section: Basic configurations.
#==============================================================================
## Nhopkg basic variables and configurations. Please don't edit these.
# Get the config file.
prefix="@prefix@"
NHOPKG_CONF="@sysconfdir@/nhopkg/nhopkg.conf"
NHOPKG_CONF_DEFAULT="@pkgdatadir@/nhopkg.conf"
if [[ -e "${NHOPKG_CONF}" ]]; then
	source "${NHOPKG_CONF}" 2> /dev/null
elif [[ -e "${NHOPKG_CONF_DEFAULT}" ]]; then
	echog " * Unable to locate Nhopkg configuration file!"
	echog " - Loading default Nhopkg configuration file..."
	source "${NHOPKG_CONF_DEFAULT}" 2> /dev/null
else
	echog " * Unable to locate Nhopkg configuration file!"
	exit 1
fi

# Get core common functions
if [[ -e "${NHOPKG_LIB}" ]]; then
	source "${NHOPKG_LIB}" 2> /dev/null
else
	echog " * Unable to locate Nhopkg core common functions file!"
fi

#==============================================================================
# Section: Unified Dependency Resolution System 
# Replaces: check_post_dependencies, check_optional_post_dependencies, 
# check_build_dependencies, downloadrequiredeps, installdownloadedeps, etc.
#==============================================================================
#----------------------------------------------------------
# Global Dependency Resolution Arrays
#----------------------------------------------------------
declare -a RCASEPACKAGES=()		# Required packages from repos
declare -a ORCASEPACKAGES=()	   # Optional packages from repos
declare -a DCASEPACKAGES=()		# Downloaded packages queue
declare -A DEP_RESOLVED_CACHE=()   # Cache: spec -> pkgfile path
declare -A DEP_REPO_CACHE=()	   # Cache: spec -> repo name
declare   DEP_FOUND_REPO=""		# Last found repository
declare   DEP_REPLACE_PACKAGE=""   # Package to be replaced

#==============================================================================
# Section: Core Dependency Resolution Functions (PUBLIC API)
#==============================================================================
#----------------------------------------------------------
# dep_resolve_from_nhoid() - Resuelve dependencias DESDE un archivo nhoid
#----------------------------------------------------------
# Esta es la función principal que reemplaza a check_*_dependencies()
# Lee las dependencias directamente del archivo nhoid del paquete
#
# Parámetros:
#   $1 - Ruta al archivo nhoid
#   $2 - Tipo: "required" | "optional" | "build" | "optional_build"
#   $3 - Silencioso: "yes" | "no" (default: no)
#   $4 - Repositorios: lista separada por espacios (default: NHOPKG_ACTIVE_REPOS)
#----------------------------------------------------------
dep_resolve_from_nhoid() {
	local nhoid_file="$1"
	local dep_type="${2:-required}"
	local silent="${3:-no}"
	local search_repos="${4:-${NHOPKG_ACTIVE_REPOS}}"
	local dep_pattern
	local deps_found=0
	
	# Determinar patrón de búsqueda según tipo de dependencia
	case "$dep_type" in
		required)
			dep_pattern="^# Dep(post):"
			;;
		optional)
			dep_pattern="^# OptionalDep(post):"
			;;
		build)
			dep_pattern="^# BuildDep:"
			;;
		optional_build)
			dep_pattern="^# OptionalBuildDep:"
			;;
		*)
			echog " *** Unknown dependency type: ${dep_type}" >&2
			return 1
			;;
	esac
	
	# Mostrar encabezado solo si no es silencioso
	if [[ "$silent" != "yes" ]]; then
		local type_label
		case "$dep_type" in
			required) type_label="required" ;;
			optional) type_label="optional" ;;
			build) type_label="build" ;;
			optional_build) type_label="optional build" ;;
		esac
		echogn " --- Processing Dependency:"
		echo " (${type_label})"
	fi
	
	# Leer cada línea de dependencias del nhoid
	while IFS= read -r dep_line; do
		# Extraer lista de dependencias (segundo campo después del tab)
		local deps=$(echo "$dep_line" | awk -F'\t' '{print $2}')
		[[ -z "$deps" ]] && continue
		
		# Procesar cada dependencia en la línea
		for dep_spec in $deps; do
			[[ -z "$dep_spec" ]] && continue
			((deps_found++))
			
			if ! _dep_resolve_single "$dep_spec" "$dep_type" "yes" "$silent" "$search_repos"; then
				# Si es required o build, fallar inmediatamente con exit 1
				if [[ "$dep_type" = "required" ]] || [[ "$dep_type" = "build" ]]; then
					echog " *** Dependency resolution failed for: ${dep_spec}" >&2
					exit 1  # ← Sale del script completo (trap hace cleanup)
				fi
				# Si es optional, continuar pero con warning
				echog " *** Optional dependency not found: ${dep_spec}"
			fi
		done
	done < <(grep "$dep_pattern" "$nhoid_file" 2>/dev/null)
	
	if [[ "$silent" != "yes" ]] && [[ $deps_found -eq 0 ]]; then
		echog "   - No ${dep_type} dependencies found"
	fi
	
	return 0
}
#----------------------------------------------------------
# dep_install_queue() - Instala toda la cola de dependencias
#----------------------------------------------------------
# Parámetros:
#   $1 - Preguntar al usuario: "yes" | "no" (default: yes)
#   $2 - Tipo: "required" | "optional" | "all" (default: required)
#----------------------------------------------------------
dep_install_queue() {
	local ask_user="${1:-yes}"
	local dep_type="${2:-required}"
	
	local -a queue=()
	
	# Construir cola según tipo
	case "$dep_type" in
		required)
			queue=("${RCASEPACKAGES[@]}")
			;;
		optional)
			queue=("${ORCASEPACKAGES[@]}")
			;;
		all)
			queue=("${RCASEPACKAGES[@]}" "${ORCASEPACKAGES[@]}")
			;;
	esac
	
	[[ ${#queue[@]} -eq 0 ]] && return 0
	
	# Preguntar al usuario si corresponde
	if [[ "$ask_user" = "yes" ]]; then
		local pkg_display="${pkgname}-${pkgversion}-${pkgrevision}"
		
		if [[ ${#queue[@]} -eq 1 ]]; then
			echo -en "${BOLD}"
			echo -n "${pkg_display} "
			echo -en "${NORMAL}"
			echogn "needs this dependency:"
		else
			echo -en "${BOLD}"
			echo -n "${pkg_display} "
			echo -en "${NORMAL}"
			echogn "needs the following dependencies:"
		fi
		
		local IFS=,
		echo " ${queue[*]}."
		local IFS="${OLDIFS}"
		
		nhopkg_ask_follow || return 1
		
		# Marcar como aprobado para instalación
		case "$dep_type" in
			required) Q_INSTALL_REQUIRED_DEPS="0" ;;
			optional) Q_INSTALL_OPT_DEPS="0" ;;
		esac
	fi
	
	# Descargar todos los paquetes de la cola
	_dep_download_all "${queue[@]}"
	
	# Instalar todos los paquetes descargados
	_dep_install_all_from_queue
		
	# Limpiar colas
	case "$dep_type" in
		required) RCASEPACKAGES=() ;;
		optional) ORCASEPACKAGES=() ;;
		all) RCASEPACKAGES=(); ORCASEPACKAGES=();;
	esac
	
	return 0
}
#----------------------------------------------------------
# dep_check_conflicts() - Verificación unificada de conflictos
#----------------------------------------------------------
# Parámetros:
#   $1 - Ruta al archivo nhoid
#----------------------------------------------------------
dep_check_conflicts() {
	local nhoid_file="$1"
	local new_pkgname new_pkgversion new_pkgrevision
	
	get_basic_data "${nhoid_file}"
	new_pkgname="$pkgname"
	new_pkgversion="$pkgversion"
	new_pkgrevision="$pkgrevision"
	
	# Extraer Provides y Conflicts
	local provides_list=()
	local conflicts_specs=()
	
	while IFS= read -r line; do
		local value=$(echo "$line" | awk -F'\t' '{print $2}')
		[[ -n "$value" ]] && read -ra items <<< "$value" && provides_list+=("${items[@]}")
	done < <(grep "^# Provides:" "${nhoid_file}" 2>/dev/null)
	
	while IFS= read -r line; do
		local value=$(echo "$line" | awk -F'\t' '{print $2}')
		[[ -n "$value" ]] && read -ra items <<< "$value" && conflicts_specs+=("${items[@]}")
	done < <(grep "^# Conflicts:" "${nhoid_file}" 2>/dev/null)
	
	[[ ${#conflicts_specs[@]} -eq 0 ]] && return 0
	
	echog " - Checking for conflicts..."
	DEP_REPLACE_PACKAGE=""
	
	for conflict_spec in "${conflicts_specs[@]}"; do
		# Parsear especificación de conflicto
		_dep_parse_spec "$conflict_spec"
		local name="$DEP_PARSED_NAME"
		local op="$DEP_PARSED_OP"
		local ver="$DEP_PARSED_VERSION"
		
		# 1. Verificar paquete instalado con nombre exacto
		if [[ -f "${NHOPKG_LOCALSTATEDIR}/packages/${name}" ]]; then
			# Verificar si el nuevo paquete lo provee (caso de reemplazo)
			if [[ " ${provides_list[@]} " == *" ${name} "* ]]; then
				echog "   ⚠ ${new_pkgname} will REPLACE '${name}'"
				DEP_REPLACE_PACKAGE="$name"
				continue
			fi
			
			# Comparar versiones
			get_basic_data "${NHOPKG_LOCALSTATEDIR}/packages/${name}"
			local inst_ver="${pkgversion}-${pkgrevision}"
			
			if [[ -n "$op" ]]; then
				if version_compare "$inst_ver" "$op" "$ver"; then
					echog " *** CONFLICT: ${new_pkgname} vs ${name} (${op}${ver})" >&2
					return 1
				fi
			else
				echog " *** CONFLICT: ${new_pkgname} vs ${name}" >&2
				return 1
			fi
		fi
		
		# 2. Verificar paquetes que proveen este nombre (LEVEL 2 - Provides)
		for installed_pkg in "${NHOPKG_LOCALSTATEDIR}/packages/"*; do
			[[ -f "$installed_pkg" ]] || continue
			[[ -L "$installed_pkg" ]] && continue
			
			local prov_line=$(grep "^# Provides:" "$installed_pkg" 2>/dev/null)
			[[ -z "$prov_line" ]] && continue
			
			for prov in $(echo "$prov_line" | sed 's/^# Provides:[[:space:]]*//'); do
				if [[ "$prov" == "$name" ]] || [[ "$prov" == "$name="* ]]; then
					get_basic_data "$installed_pkg"
					local prov_ver="${pkgversion}-${pkgrevision}"
					
					if [[ -n "$op" ]]; then
						if version_compare "$prov_ver" "$op" "$ver"; then
							echog " *** CONFLICT: ${new_pkgname} vs provider of ${name}" >&2
							return 1
						fi
					else
						echog " *** CONFLICT: ${new_pkgname} vs provider of ${name}" >&2
						return 1
					fi
				fi
			done
		done
	done
	
	return 0
}
#==============================================================================
# Section: Internal Helper Functions (PRIVATE - prefix _)
#==============================================================================
#----------------------------------------------------------
# _dep_resolve_single() - Resuelve UNA dependencia específica
#----------------------------------------------------------
_dep_resolve_single() {
	local spec="$1"
	local dep_type="$2"
	local recursive="${3:-yes}"
	local silent="${4:-no}"
	local search_repos="${5:-${NHOPKG_ACTIVE_REPOS}}"
	
	local name op version pkgfile repo
	
	[[ -z "$search_repos" ]] && search_repos="extra"
	
	# 1. Parsear especificación
	_dep_parse_spec "$spec"
	name="$DEP_PARSED_NAME"
	op="$DEP_PARSED_OP"
	version="$DEP_PARSED_VERSION"
	
	# 2. Verify cache
	if [[ -n "${DEP_RESOLVED_CACHE[$spec]}" ]]; then
		[[ "$silent" != "yes" ]] && echog "   - ${spec}: (cached from ${DEP_REPO_CACHE[$spec]})"
		return 0
	fi
	
	# 3. Search installed (LEVEL 1 + LEVEL 2)
	pkgfile=$(_dep_find_installed "$name" "$op" "$version")
	if [[ -n "$pkgfile" ]]; then
		DEP_RESOLVED_CACHE[$spec]="$pkgfile"
		DEP_REPO_CACHE[$spec]="local"
		[[ "$silent" != "yes" ]] && echog "   - ${spec}: (installed)"
		return 0
	fi
	
	# 4. Search on repos (LEVEL 1 + LEVEL 2 + MULTIREPO)
	pkgfile=$(_dep_find_in_repos "$name" "$op" "$version" "$search_repos")
	if [[ -n "$pkgfile" ]]; then
		DEP_RESOLVED_CACHE[$spec]="$pkgfile"
		DEP_REPO_CACHE[$spec]="$DEP_FOUND_REPO"
		
		# Add to queue by type
		case "$dep_type" in
			required|build)
				RCASEPACKAGES+=("$(basename "$pkgfile")")
				;;
			optional|optional_build)
				ORCASEPACKAGES+=("$(basename "$pkgfile")")
				;;
		esac
		
		[[ "$silent" != "yes" ]] && echog "   - ${spec}: (${DEP_FOUND_REPO:-repos})"
		
		# 5. Resolve dependencies recursively
		if [[ "$recursive" = "yes" ]]; then
			_dep_resolve_children "$pkgfile" "$dep_type" "$silent" "$search_repos"
		fi
		return 0
	fi
	
	# 6. Failed - handle according to type
	if [[ "$dep_type" = "required" ]] || [[ "$dep_type" = "build" ]]; then
		[[ "$silent" != "yes" ]] && echog " *** ${spec} (NOT FOUND)" >&2
		return 1
	else
		[[ "$silent" != "yes" ]] && echog "   ⚠ ${spec} (optional, skipped)"
		return 0
	fi
}

#----------------------------------------------------------
# _dep_parse_spec() - Parse package specification
#----------------------------------------------------------
_dep_parse_spec() {
	local spec="$1"
	DEP_PARSED_NAME=""
	DEP_PARSED_OP=""
	DEP_PARSED_VERSION=""
	
	if [[ "$spec" == *">="* ]]; then
		DEP_PARSED_NAME="${spec%%>=*}"
		DEP_PARSED_OP=">="
		DEP_PARSED_VERSION="${spec#*>=}"
	elif [[ "$spec" == *"<="* ]]; then
		DEP_PARSED_NAME="${spec%%<=*}"
		DEP_PARSED_OP="<="
		DEP_PARSED_VERSION="${spec#*<=}"
	elif [[ "$spec" == *"!="* ]]; then
		DEP_PARSED_NAME="${spec%%!=*}"
		DEP_PARSED_OP="!="
		DEP_PARSED_VERSION="${spec#*!=}"
	elif [[ "$spec" == *">"* ]]; then
		DEP_PARSED_NAME="${spec%%>*}"
		DEP_PARSED_OP=">"
		DEP_PARSED_VERSION="${spec#*>}"
	elif [[ "$spec" == *"<"* ]]; then
		DEP_PARSED_NAME="${spec%%<*}"
		DEP_PARSED_OP="<"
		DEP_PARSED_VERSION="${spec#*<}"
	elif [[ "$spec" == *"=="* ]]; then
		DEP_PARSED_NAME="${spec%%==*}"
		DEP_PARSED_OP="="
		DEP_PARSED_VERSION="${spec#*==}"
	elif [[ "$spec" == *"="* ]]; then
		DEP_PARSED_NAME="${spec%%=*}"
		DEP_PARSED_OP="="
		DEP_PARSED_VERSION="${spec#*=}"
	else
		DEP_PARSED_NAME="$spec"
		DEP_PARSED_OP=""
		DEP_PARSED_VERSION=""
	fi
	
	# Clean spaces
	DEP_PARSED_NAME="${DEP_PARSED_NAME// /}"
	DEP_PARSED_VERSION="${DEP_PARSED_VERSION// /}"
}

#----------------------------------------------------------
# _dep_find_installed() - Search installed package (LEVEL 1 + LEVEL 2)
#----------------------------------------------------------
# LEVEL 1: Direct search by package name (FAST)
# LEVEL 2: Search by Provides for virtual libraries (MEDIUM)
#----------------------------------------------------------
_dep_find_installed() {
	local name="$1"
	local op="$2"
	local version="$3"
	local pkgfile best_match best_ver
	
	# ==========================================================
	# LEVEL 1: Direct search by package name (FAST)
	# ==========================================================
	for pkgfile in "${NHOPKG_LOCALSTATEDIR}/packages/${name}"* ; do
		[[ -f "$pkgfile" ]] || continue
		[[ -L "$pkgfile" ]] && continue
		
		local bn=$(basename "$pkgfile")
		local ver_rev="${bn#${name}-}"
		[[ "$bn" == "$name" ]] && ver_rev="0"
		
		if [[ -n "$op" ]]; then
			version_compare "$ver_rev" "$op" "$version" || continue
		fi
		
		if [[ -z "$best_ver" ]] || version_compare "$ver_rev" ">" "$best_ver"; then
			best_ver="$ver_rev"
			best_match="$pkgfile"
		fi
	done
	
	# ==========================================================
	# LEVEL 2: Search by Provides (MEDIUM)
	# ==========================================================
	# Esto cubre: librerías .so, virtual packages, pkgconfig, etc.
	if [[ -z "$best_match" ]]; then
		for pkgfile in "${NHOPKG_LOCALSTATEDIR}/packages/"* ; do
			[[ -f "$pkgfile" ]] || continue
			[[ -L "$pkgfile" ]] && continue
			
			if _dep_provides_package "$pkgfile" "$name" "$op" "$version"; then
				best_match="$pkgfile"
				break
			fi
		done
	fi
	
	echo "$best_match"
}

#----------------------------------------------------------
# _dep_find_in_repos() - Search on repos (LEVEL 1 + LEVEL 2 + MULTIREPO)
#----------------------------------------------------------
# LEVEL 1: Direct search by name in repositories (FAST)
# LEVEL 2: Provides on repos (MEDIUM)
#----------------------------------------------------------
_dep_find_in_repos() {
	local name="$1"
	local op="$2"
	local version="$3"
	local search_repos="${4:-${NHOPKG_ACTIVE_REPOS}}"
	
	local repo pkgfile best_match best_ver
	
	[[ -z "$search_repos" ]] && search_repos="extra"
	DEP_FOUND_REPO=""
	
	# ==========================================================
	# LEVEL 1: Direct search by name in repositories (FAST)
	# ==========================================================
	for repo in $search_repos; do
		local pkgdir="${NHOPKG_LOCALSTATEDIR}/repo/${repo}/packages"
		[[ -d "$pkgdir" ]] || continue
		
		# Match exacto
		if [[ -f "$pkgdir/$name" ]]; then
			local ver_rev=$(basename "$pkgdir/$name" | sed "s/^${name}-//")
			[[ "$ver_rev" == "$name" ]] && ver_rev="0"
			
			if [[ -n "$op" ]]; then
				version_compare "$ver_rev" "$op" "$version" || continue
			fi
			
			if [[ -z "$best_ver" ]] || version_compare "$ver_rev" ">" "$best_ver"; then
				best_ver="$ver_rev"
				best_match="$pkgdir/$name"
				DEP_FOUND_REPO="$repo"
			fi
		fi
		
		# Match versioned
		for pkgfile in "$pkgdir/${name}"-* ; do
			[[ -f "$pkgfile" ]] || continue
			[[ -L "$pkgfile" ]] && continue
			
			local bn=$(basename "$pkgfile")
			local ver_rev="${bn#${name}-}"
			
			if [[ -n "$op" ]]; then
				version_compare "$ver_rev" "$op" "$version" || continue
			fi
			
			if [[ -z "$best_ver" ]] || version_compare "$ver_rev" ">" "$best_ver"; then
				best_ver="$ver_rev"
				best_match="$pkgfile"
				DEP_FOUND_REPO="$repo"
			fi
		done
	done
	
	# ==========================================================
	# LEVEL 2: Provides on repos (MEDIUM)
	# ==========================================================
	if [[ -z "$best_match" ]]; then
		resolve_virtual_package "$name"
		if [[ -n "$RESOLVED_PKGFILE" ]]; then
			best_match="$RESOLVED_PKGFILE"
			DEP_FOUND_REPO="$RESOLVED_REPO"
		fi
	fi

	echo "$best_match"
}

#----------------------------------------------------------
# _dep_resolve_children() - Resolves one package dependencies
#----------------------------------------------------------
_dep_resolve_children() {
	local pkgfile="$1"
	local dep_type="$2"
	local silent="$3"
	local search_repos="$4"
	
	local dep_pattern
	
	case "$dep_type" in
		build) dep_pattern="^# BuildDep:" ;;
		required) dep_pattern="^# Dep(post):" ;;
		optional) dep_pattern="^# OptionalDep(post):" ;;
		optional_build) dep_pattern="^# OptionalBuildDep:" ;;
	esac
	
	while IFS= read -r dep_line; do
		local deps=$(echo "$dep_line" | awk -F'\t' '{print $2}')
		for dep in $deps; do
			[[ -n "$dep" ]] && _dep_resolve_single "$dep" "$dep_type" "yes" "$silent" "$search_repos"
		done
	done < <(grep "$dep_pattern" "$pkgfile" 2>/dev/null)
}
#----------------------------------------------------------
# _dep_provides_package() - Check if the package provides a name
#----------------------------------------------------------
_dep_provides_package() {
	local pkgfile="$1"
	local name="$2"
	local op="$3"
	local ver="$4"
	
	local provides_line=$(grep "^# Provides:" "$pkgfile" 2>/dev/null)
	[[ -z "$provides_line" ]] && return 1
	
	for prov in $(echo "$provides_line" | sed 's/^# Provides:[[:space:]]*//'); do
		if [[ "$prov" == "$name" ]] || [[ "$prov" == "$name="* ]]; then
			if [[ -n "$op" ]]; then
				get_basic_data "$pkgfile"
				local pkg_ver="${pkgversion}-${pkgrevision}"
				version_compare "$pkg_ver" "$op" "$ver" && return 0
				return 1
			fi
			return 0
		fi
	done
	return 1
}
#----------------------------------------------------------
# _dep_download_all() - Download multiple packages
#----------------------------------------------------------
_dep_download_all() {
	local specs=("$@")
	
	for pkg_basename in "${specs[@]}"; do
		# Search package on repos
		local pkgfile=""
		for repo in ${NHOPKG_ACTIVE_REPOS}; do
			if [[ -f "${NHOPKG_LOCALSTATEDIR}/repo/${repo}/packages/${pkg_basename}" ]]; then
				pkgfile="${NHOPKG_LOCALSTATEDIR}/repo/${repo}/packages/${pkg_basename}"
				DEP_FOUND_REPO="$repo"
				break
			fi
		done
		
		[[ -z "$pkgfile" ]] && continue
		
		get_nhoid_data "$pkgfile"
		local nho_name="${pkgname}-${pkgversion}-${pkgrevision}.${pkgos}-${pkgarch}.nho"
		
		echogn " --- Downloading from "
		echo -n "${DEP_FOUND_REPO}: "
		echo "$nho_name"
		
		local repo_url=$(get_repo_url "$DEP_FOUND_REPO")
		
		wget --https-only -cqt 3 -T 20  --directory-prefix="${NHOPKG_LOCALSTATEDIR}/cache"  "${repo_url}/${nho_name}"
		check_if_ok " *** Failed to download package."
		
		DCASEPACKAGES+=("$nho_name")
	done
}
#----------------------------------------------------------
# _dep_install_all_from_queue() - Install all downloaded packages
#----------------------------------------------------------
_dep_install_all_from_queue() {
	for DCASEPACKAGE in ${DCASEPACKAGES[*]}; do
		_dep_install_single "$DCASEPACKAGE"
	done
	DCASEPACKAGES=()
}
#----------------------------------------------------------
# _dep_install_single() - Install a single package
#----------------------------------------------------------
_dep_install_single() {
	local pkg_basename="$1"
	make_tmp_dir
		
	local pkgfile="${NHOPKG_LOCALSTATEDIR}/cache/${pkg_basename}"
	[[ -f "$pkgfile" ]] || return 1
	
	tar xfC "$pkgfile" "$NHOPKG_TMPDIR"
	check_if_ok " * Unable to uncompress package."
	
	# Get data from package. Checks that is good package and get data from it.
	if [[ -f "${NHOPKG_TMPDIR}/nhoid" ]]; then
		get_nhoid_data "${NHOPKG_TMPDIR}/nhoid"
		check_package_conflicts "${NHOPKG_TMPDIR}/nhoid"
	else
		echog " * The selected package is not valid." >&2
		# Clean and exits with error.
		cleanup_tmp_dir
		return 1
	fi
	
	# Security checks.
	check_package_hash
	check_package_arch
	verify_package_signature
	
	# Handle package replacement
	if [[ -n "$DEP_REPLACE_PACKAGE" ]]; then
		remove_replaced_package "$DEP_REPLACE_PACKAGE"
	fi
	
	# Install & configure
	bin_install
	bin_install_setting_up
	bin_install_create_config_files
}
#==============================================================================
# Section: Compatibility Wrappers (LEGACY - For smooth transition)
# These functions maintain compatibility with existing code.
#==============================================================================
#----------------------------------------------------------
# check_package_conflicts() - Legacy wrapper (usa nueva implementación)
#----------------------------------------------------------
check_package_conflicts() {
	local nhoid_file="$1"
	dep_check_conflicts "$nhoid_file"
}
#==============================================================================
# End of Section: Unified Dependency Resolution System 
#==============================================================================
# ---------------------------------------------------------
# resolve_virtual_package()
# Parameters: resolve_virtual_package <name>
# Sets: RESOLVED_PKGFILE, RESOLVED_REPO
# ---------------------------------------------------------
resolve_virtual_package()
{
	local search_name="$1"
	local repo pkgdir pkgfile provides_line provs p

	RESOLVED_PKGFILE=""
	RESOLVED_REPO=""

	for repo in ${NHOPKG_ACTIVE_REPOS}; do
		pkgdir="${NHOPKG_LOCALSTATEDIR}/repo/${repo}/packages"
		[[ -d "$pkgdir" ]] || continue

		while IFS= read -r pkgfile; do
			[[ -L "$pkgfile" ]] && continue

			provides_line=$(grep "^# Provides:" "$pkgfile" 2>/dev/null)
			[[ -n "$provides_line" ]] || continue

			provs=$(echo "$provides_line" | sed 's/^# Provides:[[:space:]]*//')

			for p in $provs; do
				case "$p" in
					"$search_name"|"$search_name"=*)
						RESOLVED_PKGFILE="$pkgfile"
						RESOLVED_REPO="$repo"
						break 3
						;;
				esac
			done
		done < <(find "$pkgdir" -maxdepth 1 -type f 2>/dev/null | sort -V)
	done
}
# ---------------------------------------------------------
# append_npostinstall()
# Description: Extracts and accumulates the commands defined in the
#    npostinstall() section of a package nhoid into a deferred
#    postinstall script when --root is used.
#
#    This prevents execution of post-install actions on the host
#    system and allows them to be executed later inside a chroot.
#
#    Empty or placeholder postinstall definitions
#    (noemptyfuncs or :) are ignored.
#
# Parameters: none
# Returns: 0 if no valid npostinstall section exists,
#		  if it is empty, or after successfully appending
#		  its commands to the postinstall script.
# ---------------------------------------------------------
append_npostinstall() {
	[ -z "$NHOPKG_ROOT" ] && return 0

	POSTROOT="$NHOPKG_ROOT/usr/local/bin"
	POSTSCRIPT="$POSTROOT/postinstall.sh"
	mkdir -p "$POSTROOT"

	# Crear script si no existe
	if [ ! -f "$POSTSCRIPT" ]; then
		cat > "$POSTSCRIPT" <<'EOF'
#!/bin/sh
set -e

# NeonatoX accumulated postinstall
# Run only on chroot

# Defensive placeholder (should never be used)
noemptyfuncs() { :; }
EOF
		chmod +x "$POSTSCRIPT"
	fi

	# Extraer cuerpo real de npostinstall desde el nhoid
	body="$(
		sed -n '/^npostinstall() {/,/^}/p' "${NHOPKG_TMPDIR}/nhoid" \
		| sed '1d;$d' \
		| sed '/^[[:space:]]*$/d'
	)"

	# Ignorar placeholders
	echo "$body" | grep -Eq '^(noemptyfuncs|:)[[:space:]]*$' && return 0

	# Si quedó vacío, no hacer nada
	[ -z "$body" ] && return 0

	{
		echo ""
		echo "# --- ${PKG_DISPLAY_NAME}-${pkgversion}-${pkgrevision} ---"
		echo "$body"
	} >> "$POSTSCRIPT"
}
# ---------------------------------------------------------
# get_packages_by_group()
# Description:
#   Lists all package filenames that belong to a given group
#   across all active repositories.
#
#   It scans the local repository metadata and matches the
#   "# Group:" field inside each package description file.
#
# Parameters:
#   $1  Group name to search (e.g. "base", "core", "libs")
#
# Behavior:
#   - Uses NHOPKG_ACTIVE_REPOS (defaults to "extra" if unset)
#   - Skips symlinks
#   - Prints only package file names (basename)
#
# Returns:
#   0 always. Output is written to stdout.
# ---------------------------------------------------------
get_packages_by_group() {
	group="$1"
	repo_dir="$NHOPKG_LOCALSTATEDIR/repo"

	[ -z "$NHOPKG_ACTIVE_REPOS" ] && NHOPKG_ACTIVE_REPOS="extra"

	for repo in $NHOPKG_ACTIVE_REPOS; do
		pkgdir="$repo_dir/$repo/packages"
		[ -d "$pkgdir" ] || continue

		find "$pkgdir" -maxdepth 1 -type f -print | while IFS= read -r pkg_file; do
			[ -L "$pkg_file" ] && continue
			pkg_group=$(sed -n 's/^# Group:[[:space:]]*//p' "$pkg_file")
			if [ "$pkg_group" = "$group" ]; then
				basename "$pkg_file"
			fi
		done
	done
}
# ---------------------------------------------------------
# install_init_unit()
# Description: Install or remove init service units using
#    external providers (BLFS).
#    Automatically selects the backend according
#    to INITSYSTEM (systemd or sysvinit).
#    Action "remove" is normalized to "uninstall".
# Parameters:
#   $1 - Action: install | remove
#   $2 - Service name (must match Makefile target name)
# Returns:
#   0 on success or if init system is unsupported.
#   1 on error (missing parameters, download/extract failure).
# ---------------------------------------------------------
install_init_unit()
{
	action="$1"	# install | remove
	service="$2"   # ej: slapd

	[ -n "$action" ] && [ -n "$service" ] || return 1

	# Normalizar acción
	[ "$action" = "remove" ] && action="uninstall"

	case "$INITSYSTEM" in
		systemd)
			dir="$SYSTEMD_BLFS_DIR"
			url="$SYSTEMD_BLFS_URL"
			;;
		sysvinit)
			dir="$SYSV_BLFS_DIR"
			url="$SYSV_BLFS_URL"
			;;
		*)
			return 0
			;;
	esac

	if [ ! -d "$dir" ]; then
		wget -qO- "$url" | tar -xJ -C /usr/src || return 1
	fi

	cd "$dir" || return 1
	echogn " --- Installing service: "
	echo "${service}"
	make "${action}-${service}"
}
# ---------------------------------------------------------
# get_package_display_name()
# Description: Returns the proper package name, applying multilib hacks.
# Parameters: part (optional)
# Returns: Proper package name in variable PKG_DISPLAY_NAME
# ---------------------------------------------------------
get_package_display_name()
{
	local part="$1"
	if [[ "$part" = "lib32" ]]; then
		PKG_DISPLAY_NAME="lib32-${pkgname}"
	else
		PKG_DISPLAY_NAME="${pkgname}${part:+-}${part}"
	fi
}
# ---------------------------------------------------------
# shooter_updates()
# Description: Generates schemas, updates icons, desktop, mime, etc.
# Parameters: updates (optional: "silent")
# ---------------------------------------------------------
shooter_updates() {
	local verbose=true update_count=0 update_errors=0
	local GLIB_SCHEMAS ICON_CACHE DESKTOP_DB MIME_DB MANDB FC_CACHE LDCONFIG GDK_PIXBUF

	# Detect commands
	GLIB_SCHEMAS=$(command -v glib-compile-schemas 2>/dev/null)
	ICON_CACHE=$(command -v gtk-update-icon-cache 2>/dev/null)
	DESKTOP_DB=$(command -v update-desktop-database 2>/dev/null)
	MIME_DB=$(command -v update-mime-database 2>/dev/null)
	MANDB=$(command -v mandb 2>/dev/null)
	FC_CACHE=$(command -v fc-cache 2>/dev/null)
	LDCONFIG=$(command -v ldconfig 2>/dev/null)
	GDK_PIXBUF=$(command -v gdk-pixbuf-query-loaders 2>/dev/null)

	[[ "$1" == "silent" ]] && verbose=false

	run_update() {
		local cmd="$1" desc="$2"; shift 2
		# Si no existe o no es ejecutable, salir silenciosamente
		[[ -z "$cmd" || ! -x "$cmd" ]] && return 0

		if $verbose; then
			echogn " --- Updating: "
			echo "${desc}"
		fi

		if "$cmd" "$@" &>/dev/null; then
			((update_count++))
			$verbose && echog "\t** OK: Update completed successfully"
		else
			((update_errors++))
			$verbose && echog "\t** Fail: Update failed"
		fi
	}

	# 1. Update GLib Schemas
	run_update "$GLIB_SCHEMAS" "$(echogn "schemas")" /usr/share/glib-2.0/schemas

	# 2. Update icon cache (Silent per theme, only existing dirs)
	if [[ -n "$ICON_CACHE" && -x "$ICON_CACHE" && -d /usr/share/icons ]]; then
		if $verbose; then
			echogn " --- Updating: "
			echogn "icons"
			echo
		fi
		for dir in /usr/share/icons/*/; do
			[[ -d "$dir" ]] && "$ICON_CACHE" -q -t -f "$dir" &>/dev/null
		done
		((update_count++))
		$verbose && echog "\t** OK: Update completed successfully"
	fi

	# 3. Update desktop database
	run_update "$DESKTOP_DB" "$(echogn "desktop entries")" /usr/share/applications

	# 4. Update MIME types
	run_update "$MIME_DB" "$(echogn "MIME database")" /usr/share/mime

	# 5. Update manual database (if changes exist)
	if [[ -n "$MANDB" && -x "$MANDB" && -d /usr/share/man ]]; then
		if [[ -e /var/cache/man/index.db ]]; then
			if find /usr/share/man -newer /var/cache/man/index.db -type f -quit &>/dev/null; then
				run_update "$MANDB" "$(echogn "manual pages")" -q
			fi
		fi
	fi

	# 6. Update font cache (if changes exist)
	if [[ -n "$FC_CACHE" && -x "$FC_CACHE" && -d /usr/share/fonts ]]; then
		if [[ -d /var/cache/fontconfig ]]; then
			if find /usr/share/fonts -newer /var/cache/fontconfig -type f -quit &>/dev/null; then
				run_update "$FC_CACHE" "$(echogn "font cache")" -f
			fi
		fi
	fi

	# 7. Update library cache (if changes exist)
	if [[ -n "$LDCONFIG" && -x "$LDCONFIG" ]]; then
		if [[ -e /etc/ld.so.cache ]]; then
			if find /usr/lib /lib -newer /etc/ld.so.cache -type f -quit &>/dev/null; then
				run_update "$LDCONFIG" "$(echogn "shared libraries")"
			fi
		fi
	fi

	# 8. Update GDK Pixbuf loaders
	run_update "$GDK_PIXBUF" "$(echogn "gdk-pixbuf loaders")" --update-cache

	# Summary
	if $verbose; then
		if ((update_count > 0 || update_errors > 0)); then
			echog " - System updates completed"
			((update_errors > 0)) && echog "   Some updates failed"
		else
			echog " - No updates were necessary"
		fi
	fi

	return $((update_errors > 0 ? 1 : 0))
}
# ---------------------------------------------------------
# print_background_title()
# Description: This prints a title.
# Parameters: message
# Returns: 0 in any way and title messages.
# ---------------------------------------------------------
print_background_title()
{
	# Get message text.
	MESSAGE="${1}"
	MESSAGE_CHARS=$(echog "${MESSAGE}" | wc -m)
	((MESSAGE_CHARS++))
	# Count colums of shell.
	SHELL_COLUMS=$(tput cols)
	TITLE_COLUMS=$((${SHELL_COLUMS} - ${MESSAGE_CHARS}))
	TITLE_COLUMS=$((${TITLE_COLUMS} / 2))
	for ((i=0;i<${TITLE_COLUMS};i++));
	do
		echo -n "="
	done
	echo -n " "
	echogn "${MESSAGE}"
	echo -n " "
	for ((i=0;i<${TITLE_COLUMS};i++));
	do
		echo -n "="
	done
	echo
	# Success.
	return 0
}
# ---------------------------------------------------------
# nhopkg_version()
# Description: Print nhopkg version. If user is in LFS based system, Nhopkg prints special message ;)
# Parameters: none
# Returns: 0 in any way and Nhopkg version.
