#!/bin/bash

###############################################################################
#	nhopkg-repos (tool) v. @PACKAGE_VERSION@ @RELEASEDATE@  <https://github.com/cargabsj175/neonatox-nhopkg/>
#
#	Copyright (C) 2009-@RELEASEDATE@  Carlos Sánchez <cargabsj175@gmail.com>
#
#	This program is free software: you can redistribute it and/or modify
#	it under the terms of the GNU General Public License as published by
#	the Free Software Foundation, either version 3 of the License, or
#	(at your option) any later version.
#
#	This program is distributed in the hope that it will be useful,
#	but WITHOUT ANY WARRANTY; without even the implied warranty of
#	MERCHANTABILITY or FITNESS FOR A PARTICULAR PURPOSE.  See the
#	GNU General Public License for more details.
#
#	You should have received a copy of the GNU General Public License
#	along with this program.  If not, see <http://www.gnu.org/licenses/>.
#
###############################################################################
# Description: Repository management tool for nhopkg package manager.
#  Operations:
#  - create-repo:      Create new repository structure from .nho packages
#  - add-to-repo:      Incrementally add .nho packages to existing repository
#  - sign, sign-all:   Sign packages with GPG
#  - verify:           Verify package GPG signature
#  - keygen:           Generate new GPG key for packager
#  - import-key:       Import public key to trusted keyring
#  - export-key:       Export public key from trusted keyring
#  - list-keys:        List trusted keys
#  - remove-key:       Remove key from trusted keyring
#  - add-repo:         Add repository to configuration
#  - remove-repo:      Remove repository from configuration
#  - list-repos:       List configured repositories
###############################################################################
#==============================================================================
# Section: Basic configurations.
#==============================================================================
## Nhopkg basic variables and configurations. Please don't edit these.
# Get the config file.
prefix="@prefix@"
NHOPKG_CONF="@sysconfdir@/nhopkg/nhopkg.conf"
NHOPKG_CONF_DEFAULT="@pkgdatadir@/nhopkg.conf"
if [[ -e "${NHOPKG_CONF}" ]]; then
	source "${NHOPKG_CONF}" 2> /dev/null
elif [[ -e "${NHOPKG_CONF_DEFAULT}" ]]; then
	echog " * Unable to locate Nhopkg configuration file!"
	echog " - Loading default Nhopkg configuration file..."
	source "${NHOPKG_CONF_DEFAULT}" 2> /dev/null
else
	echog " * Unable to locate Nhopkg configuration file!"
	exit 1
fi

# Get core common functions
if [[ -e "${NHOPKG_LIB}" ]]; then
	source "${NHOPKG_LIB}" 2> /dev/null
else
	echog " * Unable to locate Nhopkg core common functions file!"
fi

# Get crypto library (signing/verification)
NHOPKG_CRYPTO_LIB="${NHOPKG_CRYPTO_LIB:-@prefix@/lib/nhopkg/libnhopkg_crypto}"
if [[ -f "${NHOPKG_CRYPTO_LIB}" ]]; then
	source "${NHOPKG_CRYPTO_LIB}" 2> /dev/null
fi

#==============================================================================
# Section: Argument parsing
#==============================================================================
SHORTOPTIONS="g:Ao:sk:"
LONGOPTIONS="create-repo:,add-to-repo,repo-dir:,sign:,sign-all,verify:,keygen,import-key:,export-key:,list-keys,remove-key:,add-repo:,remove-repo:,list-repos,key:,batch,passphrase-file:,verify-incoming,help,version"

NHPARAMS=$(getopt -o ${SHORTOPTIONS} -l ${LONGOPTIONS} -n "nhopkg-repos" -- "$@")
[[ "${?}" != "0" ]] && { echo "Use --help for usage."; exit 1; }
eval set -- $NHPARAMS

# Variables for argument parsing
SIGN_KEY="${NHOPKG_SIGN_KEY}"
SIGN_BATCH=""
SIGN_PASSPHRASE_FILE=""
VERIFY_INCOMING=0

while [[ "${1}" != "--" ]]; do
	case "${1}" in
		-g|--create-repo)
			shift
			if [[ -d "${1}" ]]; then
				REPO_DIR="$(echo ${1} | sed -e 's@/$@@')"
			else
				echog " * The selected directory doesn't exist in your system." >&2
				exit 1
			fi
			[[ -z "${NHOPKG_OPTION}" ]] || { echog " * You have selected more than one valid option." >&2; exit 1; }
			NHOPKG_OPTION="create-repo"
			shift
		;;
		-A|--add-to-repo)
			shift
			[[ -z "${NHOPKG_OPTION}" ]] || { echog " * You have selected more than one valid option." >&2; exit 1; }
			NHOPKG_OPTION="add-to-repo"
		;;
		-o|--repo-dir)
			shift
			if [[ -d "${1}" ]]; then
				REPO_ROOT="$(echo ${1} | sed -e 's@/$@@')"
			else
				echog " * The selected directory doesn't exist in your system." >&2
				exit 1
			fi
			shift
		;;
		-s|--sign)
			shift
			[[ -z "${NHOPKG_OPTION}" ]] || { echog " * You have selected more than one valid option." >&2; exit 1; }
			NHOPKG_OPTION="sign"
			SIGN_PACKAGE="${1}"
			shift
		;;
		--sign-all)
			shift
			[[ -z "${NHOPKG_OPTION}" ]] || { echog " * You have selected more than one valid option." >&2; exit 1; }
			NHOPKG_OPTION="sign-all"
		;;
		--verify)
			shift
			[[ -z "${NHOPKG_OPTION}" ]] || { echog " * You have selected more than one valid option." >&2; exit 1; }
			NHOPKG_OPTION="verify"
			VERIFY_PACKAGE="${1}"
			shift
		;;
		--keygen)
			shift
			[[ -z "${NHOPKG_OPTION}" ]] || { echog " * You have selected more than one valid option." >&2; exit 1; }
			NHOPKG_OPTION="keygen"
		;;
		--import-key)
			shift
			[[ -z "${NHOPKG_OPTION}" ]] || { echog " * You have selected more than one valid option." >&2; exit 1; }
			NHOPKG_OPTION="import-key"
			IMPORT_KEY_SOURCE="${1}"
			shift
		;;
		--export-key)
			shift
			[[ -z "${NHOPKG_OPTION}" ]] || { echog " * You have selected more than one valid option." >&2; exit 1; }
			NHOPKG_OPTION="export-key"
			EXPORT_KEY_ID="${1}"
			shift
		;;
		--list-keys)
			shift
			[[ -z "${NHOPKG_OPTION}" ]] || { echog " * You have selected more than one valid option." >&2; exit 1; }
			NHOPKG_OPTION="list-keys"
		;;
		--remove-key)
			shift
			[[ -z "${NHOPKG_OPTION}" ]] || { echog " * You have selected more than one valid option." >&2; exit 1; }
			NHOPKG_OPTION="remove-key"
			REMOVE_KEY_ID="${1}"
			shift
		;;
		--add-repo)
			shift
			[[ -z "${NHOPKG_OPTION}" ]] || { echog " * You have selected more than one valid option." >&2; exit 1; }
			NHOPKG_OPTION="add-repo"
			ADD_REPO_NAME="${1}"
			shift
			ADD_REPO_URL="${1}"
			shift
		;;
		--remove-repo)
			shift
			[[ -z "${NHOPKG_OPTION}" ]] || { echog " * You have selected more than one valid option." >&2; exit 1; }
			NHOPKG_OPTION="remove-repo"
			REMOVE_REPO_NAME="${1}"
			shift
		;;
		--list-repos)
			shift
			[[ -z "${NHOPKG_OPTION}" ]] || { echog " * You have selected more than one valid option." >&2; exit 1; }
			NHOPKG_OPTION="list-repos"
		;;
		-k|--key)
			shift
			SIGN_KEY="${1}"
			shift
		;;
		--batch)
			shift
			SIGN_BATCH="--batch"
		;;
		--passphrase-file)
			shift
			SIGN_PASSPHRASE_FILE="--passphrase-file ${1}"
			shift
		;;
		--verify-incoming)
			shift
			VERIFY_INCOMING=1
		;;
		-h|--help)
			echog "Usage: nhopkg-repos <command> [options]"
			echo
			echog "Repository management:"
			echog "  -g, --create-repo <dir>       Create repository from directory"
			echog "  -A, --add-to-repo             Add packages to existing repository"
			echog "  -o, --repo-dir <dir>          Repository root directory"
			echog "      --add-repo <name> <url>   Add repository to configuration"
			echog "      --remove-repo <name>      Remove repository from configuration"
			echog "      --list-repos              List configured repositories"
			echo
			echog "Signing & verification:"
			echog "  -s, --sign <pkg.nho>          Sign a package"
			echog "      --sign-all                Sign unsigned packages in repo"
			echog "      --verify <pkg.nho>        Verify package signature"
			echog "      --keygen                  Generate new GPG key"
			echog "      --import-key <file|url>   Import public key"
			echog "      --export-key [<id>]       Export public key"
			echog "      --list-keys               List trusted keys"
			echog "      --remove-key <id>         Remove key from trust ring"
			echo
			echog "Options:"
			echog "  -k, --key <id>                Key to use for signing"
			echog "      --batch                   Non-interactive mode (CI/CD)"
			echog "      --passphrase-file <file>  Passphrase file (batch mode)"
			echog "      --verify-incoming         Verify incoming package signatures"
			echo
			echog "  -h, --help                    Show this help"
			echog "      --version                 Show version"
			exit 0
		;;
		--version)
			echo "nhopkg-repos @PACKAGE_VERSION@"
			echo "Copyright (C) 2009-@RELEASEDATE@  Carlos Sánchez <cargabsj175@gmail.com>"
			exit 0
		;;
		--)
			shift
			break
		;;
		*)
			shift
		;;
	esac
done

CASEPACKAGES="$@"

[[ -z "${NHOPKG_OPTION}" ]] && {
	echog " * No operation specified. Use --help." >&2
	exit 1
}

# Root validation for repo operations
if [[ "${NHOPKG_OPTION}" == "create-repo" || "${NHOPKG_OPTION}" == "add-to-repo" ]]; then
	[[ "${UID}" != "0" ]] && { echo " * Root privileges required." >&2; exit 1; }
fi

#==============================================================================
# Section: Operation dispatch
#==============================================================================
case "${NHOPKG_OPTION}" in
	#----------------------------------------------------------------------
	# sign: sign a single .nho package
	#----------------------------------------------------------------------
	sign)
		[[ -f "${SIGN_PACKAGE}" ]] || { echog " * Package not found: ${SIGN_PACKAGE}" >&2; exit 1; }
		echogn " :: Signing:"
		echo " $(basename "${SIGN_PACKAGE}")"

		# Extract data.tar.zst from the .nho
		pkg_dir=$(mktemp -d) || exit 1
		tar xf "${SIGN_PACKAGE}" -C "${pkg_dir}" data.tar.zst 2>/dev/null || {
			echog " * Invalid package." >&2; rm -rf "${pkg_dir}"; exit 1
		}

		# Check if already signed
		has_sig=0
		for sig in "${pkg_dir}"/signature*.gpg; do
			[[ -f "${sig}" ]] && { has_sig=1; break; }
		done

		if [[ ${has_sig} -eq 1 ]]; then
			echog " - Package already has a signature. Use --force to add another."
			rm -rf "${pkg_dir}"
			exit 0
		fi

		# Sign
		if crypto_sign_package_ext "${pkg_dir}/data.tar.zst" "${pkg_dir}" "${SIGN_KEY}"; then
			echog " --- Signature created: signature.gpg"

			# Repack the .nho with the new signature
			cd "${pkg_dir}" && tar cp * > "${SIGN_PACKAGE}" && cd "${CWD}"
			echog " - Package signed: $(basename "${SIGN_PACKAGE}")"
			rm -rf "${pkg_dir}"
			exit 0
		else
			echog " *** Failed to sign package." >&2
			rm -rf "${pkg_dir}"
			exit 1
		fi
		;;

	#----------------------------------------------------------------------
	# sign-all: sign all unsigned packages in a repo
	#----------------------------------------------------------------------
	sign-all)
		[[ -n "${REPO_ROOT}" ]] || { echog " * Must specify --repo-dir." >&2; exit 1; }
		[[ -d "${REPO_ROOT}" ]] || { echog " * Repository root does not exist." >&2; exit 1; }

		signed=0
		skipped=0
		failed=0

		find "${REPO_ROOT}" -name '*.nho' -print0 2>/dev/null > "${REPO_ROOT}/.nho-list.tmp"
		while IFS= read -r -d '' pkg; do
			echogn " :: $(basename "${pkg}")..."

			pkg_dir=$(mktemp -d) || continue
			tar xf "${pkg}" -C "${pkg_dir}" data.tar.zst 2>/dev/null || {
				rm -rf "${pkg_dir}"; continue
			}

			# Check for existing signature
			has_sig=0
			for sig in "${pkg_dir}"/signature*.gpg; do
				[[ -f "${sig}" ]] && { has_sig=1; break; }
			done

			if [[ ${has_sig} -eq 1 ]]; then
				echo " already signed (skipped)"
				skipped=$((skipped + 1))
				rm -rf "${pkg_dir}"
				continue
			fi

			if crypto_sign_package_ext "${pkg_dir}/data.tar.zst" "${pkg_dir}" "${SIGN_KEY}"; then
				cd "${pkg_dir}" && tar cp * > "${pkg}" && cd "${CWD}"
				echo " signed"
				signed=$((signed + 1))
			else
				echo " FAILED"
				failed=$((failed + 1))
			fi
			rm -rf "${pkg_dir}"
		done < "${REPO_ROOT}/.nho-list.tmp"
		rm -f "${REPO_ROOT}/.nho-list.tmp"

		echog " --- Sign-all complete: ${signed} signed, ${skipped} skipped, ${failed} failed."
		[[ ${failed} -eq 0 ]] || exit 1
		exit 0
		;;

	#----------------------------------------------------------------------
	# verify: verify a package signature
	#----------------------------------------------------------------------
	verify)
		[[ -f "${VERIFY_PACKAGE}" ]] || { echog " * Package not found: ${VERIFY_PACKAGE}" >&2; exit 1; }

		tmpdir=$(mktemp -d) || exit 1
		tar xf "${VERIFY_PACKAGE}" -C "${tmpdir}" data.tar.zst 2>/dev/null || {
			echog " * Invalid package." >&2; rm -rf "${tmpdir}"; exit 1
		}

		NHOPKG_TMPDIR="${tmpdir}"
		if crypto_verify_signature; then
			echog " --- Package signature is valid."
			rm -rf "${tmpdir}"
			exit 0
		else
			echog " *** Package signature verification FAILED." >&2
			rm -rf "${tmpdir}"
			exit 1
		fi
		;;

	#----------------------------------------------------------------------
	# keygen: generate new GPG key
	#----------------------------------------------------------------------
	keygen)
		crypto_generate_key --key-id "${ADD_REPO_NAME}" --name "${ADD_REPO_URL}" \
			${SIGN_BATCH} ${SIGN_PASSPHRASE_FILE}
		exit $?
		;;

	#----------------------------------------------------------------------
	# import-key: import public key to trusted keyring
	#----------------------------------------------------------------------
	import-key)
		crypto_import_key "${IMPORT_KEY_SOURCE}"
		exit $?
		;;

	#----------------------------------------------------------------------
	# export-key: export public key from trusted keyring
	#----------------------------------------------------------------------
	export-key)
		crypto_export_key "${EXPORT_KEY_ID}"
		exit $?
		;;

	#----------------------------------------------------------------------
	# list-keys: list trusted keys
	#----------------------------------------------------------------------
	list-keys)
		crypto_list_keys
		exit 0
		;;

	#----------------------------------------------------------------------
	# remove-key: remove key from trusted keyring
	#----------------------------------------------------------------------
	remove-key)
		crypto_remove_key "${REMOVE_KEY_ID}"
		exit $?
		;;

	#----------------------------------------------------------------------
	# add-repo: add repository to configuration
	#----------------------------------------------------------------------
	add-repo)
		[[ -n "${ADD_REPO_NAME}" && -n "${ADD_REPO_URL}" ]] || {
			echog " * Usage: nhopkg-repos --add-repo <name> <url>" >&2; exit 1
		}

		upper_name="${ADD_REPO_NAME^^}"
		conf="${NHOPKG_CONF}"

		# Add to NHOPKG_ACTIVE_REPOS if not already present
		if ! grep -q "NHOPKG_ACTIVE_REPOS.*${ADD_REPO_NAME}" "${conf}" 2>/dev/null; then
			sed -i "/^NHOPKG_ACTIVE_REPOS=/ s/\"$/ ${ADD_REPO_NAME}\"/" "${conf}"
			echog " --- Added ${ADD_REPO_NAME} to NHOPKG_ACTIVE_REPOS"
		else
			echog " - ${ADD_REPO_NAME} already in NHOPKG_ACTIVE_REPOS"
		fi

		# Add repo URL variable at the end of the repo section
		if ! grep -q "^NHOPKG_REPO_${upper_name}=" "${conf}" 2>/dev/null; then
			# Find the last NHOPKG_REPO_ line and insert after it
			last_line=$(grep -n "^NHOPKG_REPO_" "${conf}" 2>/dev/null | tail -1 | cut -d: -f1)
			if [[ -n "${last_line}" ]]; then
				sed -i "${last_line}a NHOPKG_REPO_${upper_name}=\"${ADD_REPO_URL}\"" "${conf}"
			else
				echo "NHOPKG_REPO_${upper_name}=\"${ADD_REPO_URL}\"" >> "${conf}"
			fi
			echog " --- Repository added: ${ADD_REPO_NAME} -> ${ADD_REPO_URL}"
		else
			echog " - NHOPKG_REPO_${upper_name} already exists in config."
		fi
		exit 0
		;;

	#----------------------------------------------------------------------
	# remove-repo: remove repository from configuration
	#----------------------------------------------------------------------
	remove-repo)
		[[ -n "${REMOVE_REPO_NAME}" ]] || {
			echog " * Usage: nhopkg-repos --remove-repo <name>" >&2; exit 1
		}

		upper_name="${REMOVE_REPO_NAME^^}"
		conf="${NHOPKG_CONF}"

		# Remove from NHOPKG_ACTIVE_REPOS
		sed -i "/^NHOPKG_ACTIVE_REPOS=/ s/ ${REMOVE_REPO_NAME}//; s/${REMOVE_REPO_NAME} //" "${conf}"

		# Comment out (don't delete) the NHOPKG_REPO_ line
		sed -i "/^NHOPKG_REPO_${upper_name}=/ s/^/# /" "${conf}"

		echog " --- Repository removed: ${REMOVE_REPO_NAME}"
		exit 0
		;;

	#----------------------------------------------------------------------
	# list-repos: list configured repositories
	#----------------------------------------------------------------------
	list-repos)
		conf="${NHOPKG_CONF}"
		echog "Active repositories:"
		for repo in ${NHOPKG_ACTIVE_REPOS}; do
			var="NHOPKG_REPO_${repo^^}"
			url="${!var}"
			echo "  ${repo} -> ${url:-<no URL>}"
		done
		exit 0
		;;

	#----------------------------------------------------------------------
	# create-repo: Create repository structure from .nho packages
	#----------------------------------------------------------------------
	create-repo)
	echogn " :: Creating software repository from:"
	echo " ${REPO_DIR}"
	REPO_OUTPUT_ROOT="${REPO_DIR}"
	get_pwd_dir
	check_if_root_uid

	if [[ ! -d "${REPO_OUTPUT_ROOT}" ]]; then
		echog " * Input/output directory does not exist: ${REPO_OUTPUT_ROOT}" >&2
		exit 1
	fi

	# Determine active repositories from config
	if [[ -z "${NHOPKG_ACTIVE_REPOS}" ]]; then
		NHOPKG_ACTIVE_REPOS=""
		for var in $(compgen -v NHOPKG_REPO_); do
			repo_name="${var#NHOPKG_REPO_}"
			if [[ -n "${!var}" ]]; then
				NHOPKG_ACTIVE_REPOS+="${repo_name} "
			fi
		done
		NHOPKG_ACTIVE_REPOS=$(echo "${NHOPKG_ACTIVE_REPOS}" | xargs)
	fi

	if [[ -z "${NHOPKG_ACTIVE_REPOS}" ]]; then
		echog " * No active repositories configured (NHOPKG_ACTIVE_REPOS is empty)." >&2
		exit 1
	fi
	echogn " :: Active Repositories:"
	for repo_name in ${NHOPKG_ACTIVE_REPOS}; do echo " - ${repo_name}"; done

	cleanup_tmp_dir
	make_tmp_dir

	# Find all .nho packages in the input directory
	nhopackage_list=()
	local _cr_tmp
	_cr_tmp=$(mktemp) || exit 1
	find "${REPO_OUTPUT_ROOT}" -maxdepth 1 -name '*.nho' -print0 > "$_cr_tmp"
	while IFS= read -r -d '' nhopackage_file; do
		nhopackage_list+=("$nhopackage_file")
	done < "$_cr_tmp"
	rm -f "$_cr_tmp"

	if (( ${#nhopackage_list[@]} == 0 )); then
		echog " *** No .nho packages found in input directory: ${REPO_OUTPUT_ROOT}" >&2
		cleanup_tmp_dir
		exit 1
	fi

	# Determine repo for each .nho and group them
	declare -A repo_packages
	for nhopackage_path in "${nhopackage_list[@]}"; do
		nhopackage_basename=$(basename "${nhopackage_path}")

		pkg_repo=$(tar xfO "${nhopackage_path}" "nhoid" 2>/dev/null | grep "^# Repository:" | awk -F'\t' '{print $2}' | tr '[:upper:]' '[:lower:]')

		if [[ -z "${pkg_repo}" ]]; then
			pkg_repo="extra"
		else
			repo_found=0
			for active_repo in ${NHOPKG_ACTIVE_REPOS}; do
				[[ "${pkg_repo}" == "${active_repo}" ]] && { repo_found=1; break; }
			done
			[[ ${repo_found} -eq 0 ]] && pkg_repo="extra"
		fi

		repo_packages["${pkg_repo}"]+="${nhopackage_path} "
		echogn " - ${nhopackage_basename}"; echo "   -> Repository: ${pkg_repo}"
	done

	# Process each active repository
	for repo_name in ${NHOPKG_ACTIVE_REPOS}; do
		repo_pkg_list_str="${repo_packages[${repo_name}]}"
		[[ -z "${repo_pkg_list_str}" ]] && { echog " :: No packages for: ${repo_name}. Skipping."; continue; }

		echogn " :: Processing repository: ${repo_name}"
		repo_pkg_list=($repo_pkg_list_str)

		repo_nho_dir="${REPO_OUTPUT_ROOT}/${repo_name}"
		mkdir -p "${repo_nho_dir}"

		repo_tmp_dir="${NHOPKG_TMPDIR}/${repo_name}_staging"
		mkdir -p "${repo_tmp_dir}"
		repo_packages_file="${repo_tmp_dir}/repo_packages.tar"
		repo_files_file="${repo_tmp_dir}/repo_files.tar"

		tar cf "${repo_packages_file}" --files-from /dev/null 2>/dev/null || touch "${repo_packages_file}"
		tar cf "${repo_files_file}" --files-from /dev/null 2>/dev/null || touch "${repo_files_file}"

		for nhopackage_path in "${repo_pkg_list[@]}"; do
			nhopackage_basename=$(basename "${nhopackage_path}")
			echogn " - Adding ${nhopackage_basename}..."

			if ! tar xfO "${nhopackage_path}" "nhoid" 2>/dev/null > "${NHOPKG_TMPDIR}/nhoid"; then
				echog " * Error extracting nhoid from ${nhopackage_path}" >&2
				cleanup_tmp_dir; exit 1
			fi

			if [[ -f "${NHOPKG_TMPDIR}/nhoid" ]]; then
				get_nhoid_data "${NHOPKG_TMPDIR}/nhoid"
			else
				echog " * Invalid nhoid in ${nhopackage_path}" >&2
				cleanup_tmp_dir; exit 1
			fi

			pkg_metadata_name="${pkgname}-${pkgversion}-${pkgrevision}"
			mv "${NHOPKG_TMPDIR}/nhoid" "${repo_tmp_dir}/${pkg_metadata_name}"
			ln -sf "${pkg_metadata_name}" "${repo_tmp_dir}/${pkgname}-${pkgversion}"
			ln -sf "${pkg_metadata_name}" "${repo_tmp_dir}/${pkgname}"

			tar rf "${repo_packages_file}" -C "${repo_tmp_dir}" "${pkg_metadata_name}" "${pkgname}-${pkgversion}" "${pkgname}"

			pkg_files_name="${pkgname}-${pkgversion}-${pkgrevision}"
			if tar -xf "${nhopackage_path}" --to-command='zstd -dc | tar -tf -' data.tar.zst > "${repo_tmp_dir}/${pkg_files_name}" 2>/dev/null; then
				tar rf "${repo_files_file}" -C "${repo_tmp_dir}" "${pkg_files_name}"
				zstd --rm "${repo_tmp_dir}/${pkg_files_name}" 2>/dev/null
			fi

			rm -f "${repo_tmp_dir}/${pkg_metadata_name}" "${repo_tmp_dir}/${pkgname}" "${repo_tmp_dir}/${pkgname}-${pkgversion}"

			dest_nho_path="${repo_nho_dir}/${nhopackage_basename}"
			if [[ "${nhopackage_path}" != "${dest_nho_path}" ]]; then
				cp "${nhopackage_path}" "${dest_nho_path}" || continue
			fi
		done

		# Compress metadata
		if [[ -f "${repo_packages_file}" ]] && [[ -s "${repo_packages_file}" ]]; then
			zstd --rm "${repo_packages_file}" 2>/dev/null || {
				echog " *** Unable to compress packages DB for ${repo_name}." >&2
				cleanup_tmp_dir; exit 1
			}
			cp "${repo_packages_file}.zst" "${repo_nho_dir}/core.packages.tar.zst" && rm -f "${repo_packages_file}.zst"
		fi

		if [[ -f "${repo_files_file}" ]] && [[ -s "${repo_files_file}" ]]; then
			zstd --rm "${repo_files_file}" 2>/dev/null || {
				echog " *** Unable to compress files DB for ${repo_name}." >&2
				cleanup_tmp_dir; exit 1
			}
			cp "${repo_files_file}.zst" "${repo_nho_dir}/core.files.tar.zst" && rm -f "${repo_files_file}.zst"
		fi

		# Update lastsync
		echo $(date -u +%s) > "${repo_nho_dir}/lastsync"

		# Create content.db
		cd "${repo_nho_dir}" && du *[0-9].nho > content.db && zstd --rm content.db && cd "${CWD}"

		# Sign repo metadata (via libnhopkg_crypto)
		crypto_sign_repo_metadata "${repo_nho_dir}" "${SIGN_KEY}"

		echog " - Repository '${repo_name}' created in ${repo_nho_dir}."
	done

	cleanup_tmp_dir
	echog " - All repository metadata created successfully."
	exit 0
	;;

	#----------------------------------------------------------------------
	# add-to-repo: Incrementally add packages to existing repository
	#----------------------------------------------------------------------
	add-to-repo)
	get_pwd_dir
	check_if_root_uid

	[ -z "$CASEPACKAGES" ] && { echog " * Must specify .nho packages." >&2; exit 1; }
	[ -z "$REPO_ROOT" ] && { echog " * Must specify --repo-dir." >&2; exit 1; }
	[ ! -d "$REPO_ROOT" ] && { echog " * Repository root does not exist." >&2; exit 1; }

	# --verify-incoming: check NHOPKG_VERIFY_INCOMING from config too
	[[ "${NHOPKG_VERIFY_INCOMING}" == "yes" ]] && VERIFY_INCOMING=1

	if [[ ${VERIFY_INCOMING} -eq 1 ]]; then
		[[ -f "${NHOPKG_TRUSTED_KEYS_DIR}/pubring.kbx" ]] || \
			crypto_init_keyring
	fi

	cleanup_tmp_dir
	make_tmp_dir

	#-----------------------------------------------------------
	# 1. Process incoming packages
	#-----------------------------------------------------------
	for pkgpath in $CASEPACKAGES; do
		case "$pkgpath" in
			--*) continue ;;
		esac

		[ ! -f "$pkgpath" ] && { echog " * Package not found: $pkgpath"; continue; }

		echogn " :: Adding package: $(basename "$pkgpath")"

		# --verify-incoming: check signature before processing
		if [[ ${VERIFY_INCOMING} -eq 1 ]]; then
			if ! crypto_verify_incoming "$pkgpath"; then
				echog " *** REJECTED: package signature not trusted." >&2
				continue
			fi
		fi

		# Extract nhoid
		tar xfO "$pkgpath" nhoid > "$NHOPKG_TMPDIR/nhoid" 2>/dev/null || {
			echog " * Invalid package."; continue
		}

		get_nhoid_data "$NHOPKG_TMPDIR/nhoid"

		repo="${pkgrepo:-extra}"
		repodir="$REPO_ROOT/$repo"
		mkdir -p "$repodir"

		# Remove older versions
		for old in "$repodir"/"${pkgname}"-*.nho; do
			[ -f "$old" ] || continue
			old_name=$(tar xfO "$old" nhoid 2>/dev/null | grep "^# Name:" | awk -F'\t' '{print $2}')
			[ "$old_name" = "$pkgname" ] && rm -f "$old"
		done

		# Sign package if it has no signature and signing is enabled
		if [[ "${NHOPKG_SIGN_PACKAGES}" == "yes" ]]; then
			has_sig=0
			pkg_tmp=$(mktemp -d) || continue
			tar xf "$pkgpath" -C "$pkg_tmp" data.tar.zst 2>/dev/null || { rm -rf "$pkg_tmp"; continue; }
			for sig in "$pkg_tmp"/signature*.gpg; do
				[[ -f "$sig" ]] && { has_sig=1; break; }
			done

			if [[ ${has_sig} -eq 0 ]]; then
				echog "   - Signing package..."
				if crypto_sign_package_ext "$pkg_tmp/data.tar.zst" "$pkg_tmp" "${SIGN_KEY}"; then
					cd "$pkg_tmp" && tar cp * > "$pkgpath" && cd "$CWD"
					echog "   - Signed."
				fi
			fi
			rm -rf "$pkg_tmp"
		fi

		cp "$pkgpath" "$repodir/"

		# Prepare repo staging structure
		mkdir -p "$NHOPKG_TMPDIR/$repo/packages" "$NHOPKG_TMPDIR/$repo/files"

		meta_name="$pkgname-$pkgversion-$pkgrevision"
		cp "$NHOPKG_TMPDIR/nhoid" "$NHOPKG_TMPDIR/$repo/packages/$meta_name"

		# Extract file list
		tar xf "$pkgpath" -C "$NHOPKG_TMPDIR" data.tar.zst 2>/dev/null
		if [ -f "$NHOPKG_TMPDIR/data.tar.zst" ]; then
			zstd -dc "$NHOPKG_TMPDIR/data.tar.zst" 2>/dev/null | \
			tar -tf - 2>/dev/null > "$NHOPKG_TMPDIR/$repo/files/$meta_name"
			rm -f "$NHOPKG_TMPDIR/data.tar.zst"
		fi
	done

	#-----------------------------------------------------------
	# 2. Rebuild repository metadata (per affected repo)
	#-----------------------------------------------------------
	for repo in "$NHOPKG_TMPDIR"/*; do
		[ -d "$repo" ] || continue

		reponame=$(basename "$repo")
		repodir="$REPO_ROOT/$reponame"
		echogn " :: Updating repository: $reponame"
		mkdir -p "$repodir"

		# ---------- PACKAGES ----------
		tmpbuild="$NHOPKG_TMPDIR/$reponame/.build.$$"
		mkdir -p "$tmpbuild"

		if [ -f "$repodir/core.packages.tar.zst" ]; then
			zstd -dc "$repodir/core.packages.tar.zst" 2>/dev/null | \
			tar xf - -C "$tmpbuild" 2>/dev/null
		fi

		for newmeta in "$repo/packages/"*; do
			[ -f "$newmeta" ] || continue
			get_basic_data "$newmeta"
			full="$pkgname-$pkgversion-$pkgrevision"
			rm -f "$tmpbuild/$pkgname"-* "$tmpbuild/$pkgname"
			cp "$newmeta" "$tmpbuild/$full"
			ln -sf "$full" "$tmpbuild/$pkgname-$pkgversion"
			ln -sf "$full" "$tmpbuild/$pkgname"
		done

		tar cf "$NHOPKG_TMPDIR/$reponame/.packages.$$" -C "$tmpbuild" . 2>/dev/null
		zstd -q -f "$NHOPKG_TMPDIR/$reponame/.packages.$$"
		cp "$NHOPKG_TMPDIR/$reponame/.packages.$$.zst" "$repodir/core.packages.tar.zst" && rm -f "$NHOPKG_TMPDIR/$reponame/.packages.$$.zst"
		rm -rf "$tmpbuild" "$NHOPKG_TMPDIR/$reponame/.packages.$$"

		# ---------- FILES ----------
		tmpfiles="$NHOPKG_TMPDIR/$reponame/.files.$$"
		mkdir -p "$tmpfiles"

		if [ -f "$repodir/core.files.tar.zst" ]; then
			zstd -dc "$repodir/core.files.tar.zst" 2>/dev/null | \
			tar xf - -C "$tmpfiles" 2>/dev/null
		fi

		for newfile in "$repo/files/"*; do
			[ -f "$newfile" ] || continue
			name=$(basename "$newfile")
			pkgbase=$(echo "$name" | sed 's/-[^-]*-[^-]*$//')
			rm -f "$tmpfiles/$pkgbase"-*
			cp "$newfile" "$tmpfiles/"
		done

		tar cf "$NHOPKG_TMPDIR/$reponame/.filesbuild.$$" -C "$tmpfiles" . 2>/dev/null
		zstd -q -f "$NHOPKG_TMPDIR/$reponame/.filesbuild.$$"
		cp "$NHOPKG_TMPDIR/$reponame/.filesbuild.$$.zst" "$repodir/core.files.tar.zst" && rm -f "$NHOPKG_TMPDIR/$reponame/.filesbuild.$$.zst"
		rm -rf "$tmpfiles" "$NHOPKG_TMPDIR/$reponame/.filesbuild.$$"

		# ---------- content.db ----------
		(
			cd "$repodir"
			for f in *.nho; do
				[ -f "$f" ] || continue
				size=$(stat -c %s "$f" 2>/dev/null)
				echo "$size $f"
			done > content.db
			zstd --rm -q -f content.db
		)

		date -u +%s > "$repodir/lastsync"

		# Sign repo metadata
		crypto_sign_repo_metadata "${repodir}" "${SIGN_KEY}"

		echog " - Repository $reponame updated."
	done

	cleanup_tmp_dir
	echog " - Incremental repository update completed."
	exit 0
	;;

esac
