msgstr "¡Buen trabajo su LFS! ;-)"

#: /home/cargabsj175/sources/NeonatoX_2026/neonatox-nhopkg/src/nhopkg.in:1110
msgid "Nhopkg version"
msgstr "Versión de Nhopkg"

#: /home/cargabsj175/sources/NeonatoX_2026/neonatox-nhopkg/src/nhopkg.in:1125
msgid "Usage: nhopkg [command] [options] package"
msgstr "Uso: nhopkg [comando] [opciones] paquete"

#: /home/cargabsj175/sources/NeonatoX_2026/neonatox-nhopkg/src/nhopkg.in:1126
#: /home/cargabsj175/sources/NeonatoX_2026/neonatox-nhopkg/src/nhopkg.in:1139
msgid "To see the help: nhopkg --help"
msgstr "Para ver la ayuda: nhopkg --help"

#: /home/cargabsj175/sources/NeonatoX_2026/neonatox-nhopkg/src/nhopkg.in:1138
msgid "Usage: sudo nhopkg [command] [options] package"
msgstr "Uso: sudo nhopkg [comando] [opciones] paquete"

#: /home/cargabsj175/sources/NeonatoX_2026/neonatox-nhopkg/src/nhopkg.in:1153
msgid "This program comes with ABSOLUTELY NO WARRANTY."
msgstr "Este programa viene SIN ABSOLUTA GARANTÍA"

#: /home/cargabsj175/sources/NeonatoX_2026/neonatox-nhopkg/src/nhopkg.in:1154
msgid ""
"This is free software, and you are welcome to redistribute it under certain "
"conditions; for details type nhopkg --license-all."
msgstr ""
"Esto es software libre, y usted es bienvenido para distribuirlo bajo ciertas "
"condiciones; para más detalles escriba nhopkg --license-all"

#: /home/cargabsj175/sources/NeonatoX_2026/neonatox-nhopkg/src/nhopkg.in:1168
msgid "Examples:"
msgstr "Ejemplos:"

#: /home/cargabsj175/sources/NeonatoX_2026/neonatox-nhopkg/src/nhopkg.in:1169
msgid " * Install binary package"
msgstr " * Instalar paquete binario"

#: /home/cargabsj175/sources/NeonatoX_2026/neonatox-nhopkg/src/nhopkg.in:1171
msgid " * Show files on package."
msgstr " * Mostrar archivos del paquete."

#: /home/cargabsj175/sources/NeonatoX_2026/neonatox-nhopkg/src/nhopkg.in:1174
msgid "Commands:"
msgstr "Comandos:"

#: /home/cargabsj175/sources/NeonatoX_2026/neonatox-nhopkg/src/nhopkg.in:1175
msgid " -B, --backup\tCreates binary package from installed package."
msgstr " -B, --backup\tCrea un paquete binario a partir del paquete instalado."

#: /home/cargabsj175/sources/NeonatoX_2026/neonatox-nhopkg/src/nhopkg.in:1176
msgid " -C, --super-build\tCompiles and installs source package from Git repo."
msgstr ""
" -C, --super-build\tCompila e instala el paquete fuente desde el repositorio "
"Git."

#: /home/cargabsj175/sources/NeonatoX_2026/neonatox-nhopkg/src/nhopkg.in:1177
msgid ""
" -G, --install-group\tInstalls binaries packages from a specified group from "
"the repository."
msgstr ""
" -G, --install-group\tInstala paquetes binarios de un grupo especificado "
"desde el repositorio."

#: /home/cargabsj175/sources/NeonatoX_2026/neonatox-nhopkg/src/nhopkg.in:1178
msgid " -S, --super-install\tInstalls binary package form repository."
msgstr " -S, --super-install\tInstala el paquete binario desde el repositorio."

#: /home/cargabsj175/sources/NeonatoX_2026/neonatox-nhopkg/src/nhopkg.in:1179
msgid " -U, --update\tUpdate repository database."
msgstr " -U, --update\tActualiza la base de datos del repositorio."

#: /home/cargabsj175/sources/NeonatoX_2026/neonatox-nhopkg/src/nhopkg.in:1180
msgid ""
" -X, --strip-binaries\tRemove debug symbols from installed binaries and "
"libraries during installation (experimental)."
msgstr ""
" -X, --strip-binaries\tElimina los símbolos de depuración de los binarios y "
"bibliotecas instalados durante la instalación (experimental)."

#: /home/cargabsj175/sources/NeonatoX_2026/neonatox-nhopkg/src/nhopkg.in:1182
msgid " -b, --build\tCompiles and installs source package."
msgstr " -b, --build\tCompila e instala el paquete fuente."

#: /home/cargabsj175/sources/NeonatoX_2026/neonatox-nhopkg/src/nhopkg.in:1183
msgid " -d, --dios\tSame as -S, --super-install."
msgstr " -d, --dios\tIgual que -S, --super-install."

#: /home/cargabsj175/sources/NeonatoX_2026/neonatox-nhopkg/src/nhopkg.in:1184
msgid " -e, --clean\tRemove cached data."
msgstr " -e, --clean\tEliminar datos en caché."

#: /home/cargabsj175/sources/NeonatoX_2026/neonatox-nhopkg/src/nhopkg.in:1185
msgid " -i, --install\tInstalls binary package."
msgstr " -i, --install\tInstala el paquete binario."

#: /home/cargabsj175/sources/NeonatoX_2026/neonatox-nhopkg/src/nhopkg.in:1186
msgid " -k, --check\tChecks if installed package is correct."
msgstr " -k, --check\tComprueba si el paquete instalado es correcto."

#: /home/cargabsj175/sources/NeonatoX_2026/neonatox-nhopkg/src/nhopkg.in:1187
msgid " -l, --list\tLists installed packages."
msgstr " -l, --list\tEnumera los paquetes instalados."

#: /home/cargabsj175/sources/NeonatoX_2026/neonatox-nhopkg/src/nhopkg.in:1188
msgid " -n, --info\tShows package details."
msgstr " -n, --info\tMuestra los detalles del paquete."

#: /home/cargabsj175/sources/NeonatoX_2026/neonatox-nhopkg/src/nhopkg.in:1189
msgid " -r, --remove\tRemoves package installed by Nhopkg."
msgstr " -r, --remove\tElimina el paquete instalado por Nhopkg."

#: /home/cargabsj175/sources/NeonatoX_2026/neonatox-nhopkg/src/nhopkg.in:1190
msgid " -s, --search\tSearch for package and its details."
msgstr " -s, --search\tBusca el paquete y sus detalles."

#: /home/cargabsj175/sources/NeonatoX_2026/neonatox-nhopkg/src/nhopkg.in:1191
msgid " -t, --list-repo\tLists packages on repository and their details."
msgstr ""
" -t, --list-repo\tEnumera los paquetes en el repositorio y sus detalles."

#: /home/cargabsj175/sources/NeonatoX_2026/neonatox-nhopkg/src/nhopkg.in:1192
msgid " -u, --update-db\tUpdate Nhopkg database."
msgstr " -u, --update-db\tActualizar base de datos de nhopkg."

#: /home/cargabsj175/sources/NeonatoX_2026/neonatox-nhopkg/src/nhopkg.in:1193
msgid " -w, --show\tShows package files."
msgstr " -w, --show\tMuestra los archivos del paquete."

#: /home/cargabsj175/sources/NeonatoX_2026/neonatox-nhopkg/src/nhopkg.in:1194
msgid " -x, --update-shooters\tUpdates all system data and schemas."
msgstr ""
" -x, --update-shooters\tActualiza todos los datos y esquemas del sistema."

#: /home/cargabsj175/sources/NeonatoX_2026/neonatox-nhopkg/src/nhopkg.in:1195
msgid " -y, --upgrade\tUpdates all installed packages."
msgstr " -y, --upgrade\tActualiza todos los paquetes instalados."

#: /home/cargabsj175/sources/NeonatoX_2026/neonatox-nhopkg/src/nhopkg.in:1196
msgid " --license-all\tShows complete Nhopkg license."
msgstr " --license-all\tMuestra la licencia completa de Nhopkg."

#: /home/cargabsj175/sources/NeonatoX_2026/neonatox-nhopkg/src/nhopkg.in:1197
msgid " --license\tShows Nhopkg license."
msgstr " --license\tMuestra la licencia de Nhopkg."

#: /home/cargabsj175/sources/NeonatoX_2026/neonatox-nhopkg/src/nhopkg.in:1198
msgid " --version\tShows Nhopkg version."
msgstr " --version\tMuestra la versión de Nhopkg."

#: /home/cargabsj175/sources/NeonatoX_2026/neonatox-nhopkg/src/nhopkg.in:1199
msgid " -h, --help\tShows this help page."
msgstr " -h, --help\tMuestra esta página de ayuda."

#: /home/cargabsj175/sources/NeonatoX_2026/neonatox-nhopkg/src/nhopkg.in:1201
#: /home/cargabsj175/sources/NeonatoX_2026/neonatox-nhopkg/src/nhouser.in:59
msgid "Options:"
msgstr "Opciones:"

#: /home/cargabsj175/sources/NeonatoX_2026/neonatox-nhopkg/src/nhopkg.in:1202
msgid " --force-check-arch\tForce check architecture."
msgstr " --force-check-arch\tForzar la comprobación de la arquitectura."

#: /home/cargabsj175/sources/NeonatoX_2026/neonatox-nhopkg/src/nhopkg.in:1203
msgid " --force-check-deps\tForce check dependencies."
msgstr " --force-check-deps\tForzar la comprobación de dependencias."

#: /home/cargabsj175/sources/NeonatoX_2026/neonatox-nhopkg/src/nhopkg.in:1204
msgid " --force-check-sums\tForce check Sums."
msgstr " --force-check-sums\tForzar comprobaciones de sumas."

#: /home/cargabsj175/sources/NeonatoX_2026/neonatox-nhopkg/src/nhopkg.in:1205
msgid " --no-check-arch\tDon't check architecture."
msgstr " --no-check-arch\tNo comprobar la arquitectura."

#: /home/cargabsj175/sources/NeonatoX_2026/neonatox-nhopkg/src/nhopkg.in:1206
msgid " --no-check-deps\tDon't check dependencies."
msgstr " --no-check-deps\tNo comprobar las dependencias."

#: /home/cargabsj175/sources/NeonatoX_2026/neonatox-nhopkg/src/nhopkg.in:1207
msgid " --no-check-sums\tDon't check Sums."
msgstr " --no-check-sums\tNo realizar comprueba sumas."

#: /home/cargabsj175/sources/NeonatoX_2026/neonatox-nhopkg/src/nhopkg.in:1208
msgid " --sign-package\tSign the binary package when building it."
msgstr " --sign-package\tFirma el paquete binario al compilarlo."

#: /home/cargabsj175/sources/NeonatoX_2026/neonatox-nhopkg/src/nhopkg.in:1209
msgid " --no-sign-package\tSkip the package signature."
msgstr " --no-sign-package\tOmitir la firma del paquete."

#: /home/cargabsj175/sources/NeonatoX_2026/neonatox-nhopkg/src/nhopkg.in:1210
msgid ""
" --verify-package-signature\tVerify the GPG signature of the package before "
"installing it."
msgstr ""
" --verify-package-signature\tVerifica la firma GPG del paquete antes de "
"instalarlo."

#: /home/cargabsj175/sources/NeonatoX_2026/neonatox-nhopkg/src/nhopkg.in:1211
msgid " --no-verify-package-signature\tSkip signature verification."
msgstr " --no-verify-package-signature\tOmitir la verificación de la firma."

#: /home/cargabsj175/sources/NeonatoX_2026/neonatox-nhopkg/src/nhopkg.in:1212
msgid " --purge\tRemove inverse dependencies of package."
msgstr " --purge\tElimina las dependencias inversas del paquete."

#: /home/cargabsj175/sources/NeonatoX_2026/neonatox-nhopkg/src/nhopkg.in:1213
msgid " --root\tSets install root."
msgstr " --root\tEstablece la ruta de instalación."

#: /home/cargabsj175/sources/NeonatoX_2026/neonatox-nhopkg/src/nhopkg.in:1214
msgid " -R, --recursive\tNhopkg works recursively."
msgstr " -R, --recursive\tNhopkg funciona recursivamente."

#: /home/cargabsj175/sources/NeonatoX_2026/neonatox-nhopkg/src/nhopkg.in:1215
msgid " -o, --output\tWrite an output log."
msgstr " -o, --output\tEscribir un registro de salida."

#: /home/cargabsj175/sources/NeonatoX_2026/neonatox-nhopkg/src/nhopkg.in:1216
msgid " -v, --verbose\tVerbose operations."
msgstr " -v, --verbose\tOperaciones detalladas."

#: /home/cargabsj175/sources/NeonatoX_2026/neonatox-nhopkg/src/nhopkg.in:1217
msgid " --\tStop parssing arguments."
msgstr " --\tDeja de procesar argumentos."

#: /home/cargabsj175/sources/NeonatoX_2026/neonatox-nhopkg/src/nhopkg.in:1233
msgid "Nhopkg is already in use..."
msgstr "Nhopkg está siendo usado..."

#: /home/cargabsj175/sources/NeonatoX_2026/neonatox-nhopkg/src/nhopkg.in:1238
msgid "Exist an older lock file, but seems that is not in use..."
msgstr "Existe un archivo lock antiguo, pero parece que no está en uso..."

#: /home/cargabsj175/sources/NeonatoX_2026/neonatox-nhopkg/src/nhopkg.in:1244
msgid " * You can't rewrite lock file."
msgstr " * No puede reescribir el archivo lock."

#: /home/cargabsj175/sources/NeonatoX_2026/neonatox-nhopkg/src/nhopkg.in:1286
msgid " --- Updating database:"
msgstr " --- Actualizando la base de datos:"

#: /home/cargabsj175/sources/NeonatoX_2026/neonatox-nhopkg/src/nhopkg.in:1304
msgid "Do you want to continue?[yes/NO]: "
msgstr "¿Desea continuar?[si/NO]: "

#: /home/cargabsj175/sources/NeonatoX_2026/neonatox-nhopkg/src/nhopkg.in:1311
msgid "yes"
msgstr "si"

#: /home/cargabsj175/sources/NeonatoX_2026/neonatox-nhopkg/src/nhopkg.in:1315
msgid "no"
msgstr "no"

#: /home/cargabsj175/sources/NeonatoX_2026/neonatox-nhopkg/src/nhopkg.in:1333
msgid "The selected package doesn't exist."
msgstr "El paquete seleccionado no existe."

#: /home/cargabsj175/sources/NeonatoX_2026/neonatox-nhopkg/src/nhopkg.in:1443
msgid " --- Checking package arch for"
msgstr " --- Comprobando arquitectura del paquete para"

#: /home/cargabsj175/sources/NeonatoX_2026/neonatox-nhopkg/src/nhopkg.in:1478
msgid " *** Architecture of package is not valid."
msgstr " *** La arquitectura de paquete no es válida."

#: /home/cargabsj175/sources/NeonatoX_2026/neonatox-nhopkg/src/nhopkg.in:1479
msgid " --- This package can be installed on the next system:"
msgstr " --- Este paquete puede ser instalado en el siguiente sistema:"

#: /home/cargabsj175/sources/NeonatoX_2026/neonatox-nhopkg/src/nhopkg.in:1514
#: /home/cargabsj175/sources/NeonatoX_2026/neonatox-nhopkg/src/nhopkg.in:1521
msgid "is installed in your system, but is deprecated. Package will be UPDATE."
msgstr ""
"está instalado en su sistema, pero es antiguo. El paquete será ACTUALIZADO."

#: /home/cargabsj175/sources/NeonatoX_2026/neonatox-nhopkg/src/nhopkg.in:1527
#: /home/cargabsj175/sources/NeonatoX_2026/neonatox-nhopkg/src/nhopkg.in:1540
msgid "is installed in your system and is newer. Package will be DOWNGRADE."
msgstr ""
"está instalado en su sistema y es más reciente. El paquete será "
"DESACTUALIZADO."

#: /home/cargabsj175/sources/NeonatoX_2026/neonatox-nhopkg/src/nhopkg.in:1533
msgid "is already installed in your system. Package will be REINSTALL."
msgstr "está instalado ya en su sistema. El paquete será REINSTALADO."

